nk rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/115dplafwys-z.js\"/><script src=\"/_next/static/chunks/04aem330ymbdp.js\" async=\"\"></script><script src=\"/_next/static/chunks/0h4bq73pogmtb.js\" async=\"\"></script><script src=\"/_next/static/chunks/00-afic.qwmjr.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-01qb.sg0_giv5.js\" async=\"\"></script><script src=\"/_next/static/chunks/0vjyk4agyz9pu.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d9y~ee11bp-a.js\" async=\"\"></script><script src=\"/_next/static/chunks/0f5gawopsa8l_.js\" async=\"\"></script><script src=\"/_next/static/chunks/14iukx7agfk3v.js\" async=\"\"></script><title>Collector&#x27;s Paradise | Pokémon Trading Card Events in Melbourne</title><meta name=\"description\" content=\"Melbourne&#x27;s premier Pokémon trading card event. Buy, sell, trade rare cards. Meet vendors, discover collections, and connect with the collector community.\"/><meta name=\"keywords\" content=\"Pokemon cards,trading cards,Melbourne events,card collecting,TCG,Pokemon TCG,card trading,rare cards,collector events\"/><meta property=\"og:title\" content=\"Collector&#x27;s Paradise | Pokémon Trading Card Events\"/><meta property=\"og:description\" content=\"Where collectors meet, trade &amp; connect. Join Melbourne&#x27;s most exciting trading card event.\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Collector&#x27;s Paradise | Pokémon Trading Card Events\"/><meta name=\"twitter:description\" content=\"Where collectors meet, trade &amp; connect. Join Melbourne&#x27;s most exciting trading card event.\"/><link rel=\"icon\" href=\"/icon.png?icon.0pbo66~93xbg6.png\" sizes=\"1024x1024\" type=\"image/png\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><main><nav class=\"navbar \"><div class=\"navbar-inner\"><a class=\"navbar-logo-link\" href=\"/\"><img alt=\"Collector&#x27;s Paradise\" width=\"180\" height=\"55\" decoding=\"async\" data-nimg=\"1\" class=\"navbar-logo\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Flogo.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fimages%2Flogo.png&amp;w=384&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Flogo.png&amp;w=384&amp;q=75\"/></a><div class=\"navbar-actions\"><div class=\"navbar-login-wrapper\"><button class=\"navbar-join-pill\">LOGIN / SIGN-UP<svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"margin-left:6px;transition:transform 0.2s;transform:rotate(0deg)\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg></button><div class=\"navbar-login-dropdown \"><div class=\"navbar-login-dropdown-inner\"><a class=\"login-dropdown-item\" href=\"/login\"><span class=\"login-item-title\">Login to Account</span><span class=\"login-item-desc\">Access your collector portal</span></a><a class=\"login-dropdown-item\" href=\"/signup\"><span class=\"login-item-title\">Sign Up as Buyer</span><span class=\"login-item-desc\">Get tickets &amp; track your orders</span></a><a class=\"login-dropdown-item\" href=\"/vendors/apply\"><span class=\"login-item-title\">Apply as Vendor</span><span class=\"login-item-desc\">Secure a booth &amp; sell your collection</span></a></div></div></div><button class=\"navbar-menu-icon \" aria-label=\"Toggle menu\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"></line><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"></line><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"></line></svg></button></div><div class=\"navbar-dropdown \"><div class=\"navbar-dropdown-inner\"><a href=\"/#about\"><span class=\"menu-item-text\">About</span></a><a href=\"/#experience\"><span class=\"menu-item-text\">Experience</span></a><a href=\"/events\"><span class=\"menu-item-text\">Events</span></a><a href=\"/vendors\"><span class=\"menu-item-text\">Vendors</span></a><a href=\"/events\"><span class=\"menu-item-text\">Tickets</span></a></div></div></div></nav><section class=\"hero\" id=\"hero\"><div class=\"hero-bg\"><video autoPlay=\"\" loop=\"\" muted=\"\" playsInline=\"\" class=\"hero-video\"><source src=\"/hero-section-video.mp4\" type=\"video/mp4\"/></video></div><div class=\"hero-content\"><h1 class=\"hero-title\">Where Collectors<br/>Meet, Trade &amp; Connect</h1><p class=\"hero-subtitle\">A live trading card event where collectors buy, sell, and trade Pokémon cards, discover rare finds, and connect with the community.</p><div class=\"hero-buttons\"><a class=\"btn btn-hero-ticket\" href=\"/events\">Buy Tickets</a></div></div><div class=\"hero-cards-fan\"><div class=\"hero-card hero-card-left\"><img alt=\"Charizard Pokemon Card\" width=\"280\" height=\"390\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Fcard1.png&amp;w=384&amp;q=75 1x, /_next/image?url=%2Fimages%2Fcard1.png&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Fcard1.png&amp;w=640&amp;q=75\"/></div><div class=\"hero-card hero-card-center\"><img alt=\"Arcanine V Pokemon Card\" width=\"300\" height=\"420\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Fcard2.png&amp;w=384&amp;q=75 1x, /_next/image?url=%2Fimages%2Fcard2.png&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Fcard2.png&amp;w=640&amp;q=75\"/></div><div class=\"hero-card hero-card-right\"><img alt=\"Pikachu ex Pokemon Card\" width=\"280\" height=\"390\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Fcard3.png&amp;w=384&amp;q=75 1x, /_next/image?url=%2Fimages%2Fcard3.png&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Fcard3.png&amp;w=640&amp;q=75\"/></div></div></section><section id=\"about\" class=\"about\"><div class=\"container\"><div class=\"about-header\" data-aos=\"fade-up\"><span class=\"eyebrow-badge\">ABOUT THE EVENT</span><h2 class=\"section-title\">WHAT IS COLLECTOR&#x27;S<br/>PARADISE?</h2><p class=\"section-subtitle\">A live trading card event bringing collectors together…</p></div><div class=\"about-pills-container\"><button class=\"about-pill\" data-aos=\"fade-up\" data-aos-delay=\"100\"><span class=\"about-pill-text\">BUY / SELL / TRADE</span><div class=\"about-pill-icon\"><svg viewBox=\"0 0 24 24\"><polyline points=\"9 18 15 12 9 6\"></polyline></svg></div></button><button class=\"about-pill\" data-aos=\"fade-up\" data-aos-delay=\"200\"><span class=\"about-pill-text\">GUEST SIGNINGS</span><div class=\"about-pill-icon\"><svg viewBox=\"0 0 24 24\"><polyline points=\"9 18 15 12 9 6\"></polyline></svg></div></button><button class=\"about-pill\" data-aos=\"fade-up\" data-aos-delay=\"300\"><span class=\"about-pill-text\">PSA CARD EVALUATIONS</span><div class=\"about-pill-icon\"><svg viewBox=\"0 0 24 24\"><polyline points=\"9 18 15 12 9 6\"></polyline></svg></div></button></div></div></section><section id=\"experience\" class=\"experience-section\"><div class=\"experience-card-container\" data-aos=\"fade-up\"><div class=\"experience-content\"><span class=\"eyebrow-badge\">WHAT YOU&#x27;LL EXPERIENCE</span><h2 class=\"section-title\">FUN FOR<br/>EVERYONE</h2><p class=\"section-subtitle\">Immerse yourself in a world of pop culture excitement. From rare collectibles to exclusive guest appearances, there&#x27;s something for every fan.</p><div class=\"experience-tags\"><span class=\"experience-tag\">BUY / SELL / TRADE</span><span class=\"experience-tag\">MEET FELLOW FANS</span><span class=\"experience-tag\">CULTURE AND FUN</span><span class=\"experience-tag\">LIVE DEAL EVALUATIONS</span></div></div><div class=\"experience-image-side\"><img alt=\"Collector&#x27;s Paradise Experience\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;object-position:center;color:transparent\" sizes=\"(max-width: 900px) 100vw, 50vw\" srcSet=\"/_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2F3rd-section-card-image.jpg&amp;w=3840&amp;q=75\"/></div></div></section><section id=\"highlights\" class=\"highlights-section\"><div class=\"container\"><div class=\"highlights-header\" data-aos=\"fade-up\"><span class=\"eyebrow-badge\">PREVIOUS &amp; UPCOMING EVENTS</span><h2 class=\"section-title\">EVENT HIGHLIGHTS</h2><p class=\"section-subtitle\">Discover everything happening at the event, from trading zones to exclusive finds.</p></div><div class=\"highlights-controls-wrapper\"><div class=\"highlights-toggle-container\"><button class=\"toggle-btn active\">Upcoming Events</button><button class=\"toggle-btn \">Past Events</button></div><div class=\"view-toggle-container\"><button class=\"view-btn view-icon-only active\" aria-label=\"Card View\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"></rect><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"></rect><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"></rect><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"></rect></svg></button><button class=\"view-btn view-icon-only \" aria-label=\"Calendar View\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"></rect><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"></line><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"></line><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"></line></svg></button></div></div><div class=\"highlights-carousel-wrapper\"><button class=\"highlights-carousel-arrow arrow-prev\" aria-label=\"Previous\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M15 18l-6-6 6-6\"></path></svg></button><div class=\"highlights-grid\"><div class=\"highlight-card\" data-aos=\"fade-up\" data-aos-delay=\"0\"><div class=\"highlight-image-wrapper\"><img alt=\"Sydney Card Show\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2F4th-card-1.png&amp;w=3840&amp;q=75\"/><div class=\"highlight-date-tag\">12 Apr</div></div><div class=\"highlight-content\"><h3 class=\"highlight-title\">Sydney Card Show</h3><p class=\"highlight-desc\">Join us at the International Convention Centre for the biggest card show in NSW. Special guests, live breaks, and thousands of graded slabs.</p><button class=\"btn-highlight\">GET YOUR TICKETS</button></div></div><div class=\"highlight-card\" data-aos=\"fade-up\" data-aos-delay=\"100\"><div class=\"highlight-image-wrapper\"><img alt=\"Melbourne Trade Day\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2F4th-card-2.jpg&amp;w=3840&amp;q=75\"/><div class=\"highlight-date-tag\">24 Apr</div></div><div class=\"highlight-content\"><h3 class=\"highlight-title\">Melbourne Trade Day</h3><p class=\"highlight-desc\">Victoria&#x27;s premier trading event. Bring your binders and slabs for a massive weekend of trading, grading submissions, and collecting.</p><button class=\"btn-highlight\">GET YOUR TICKETS</button></div></div><div class=\"highlight-card\" data-aos=\"fade-up\" data-aos-delay=\"200\"><div class=\"highlight-image-wrapper\"><img alt=\"Brisbane Collector Fest\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2F4th-card-3.jpg&amp;w=3840&amp;q=75\"/><div class=\"highlight-date-tag\">5 Apr</div></div><div class=\"highlight-content\"><h3 class=\"highlight-title\">Brisbane Collector Fest</h3><p class=\"highlight-desc\">The ultimate pop culture and card convention hits Queensland. Featuring voice actors, exclusive merch, and massive vendor halls.</p><button class=\"btn-highlight\">GET YOUR TICKETS</button></div></div><div class=\"highlight-card\" data-aos=\"fade-up\" data-aos-delay=\"300\"><div class=\"highlight-image-wrapper\"><img alt=\"Perth Pop Culture Expo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2F4th-card-4.jpg&amp;w=3840&amp;q=75 3840w\" src=